---
import { useTranslations } from "../locales/utils";
import { socialLinks } from "../data/social";
import SocialIcon from "./SocialIcon.astro";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
---

<footer class="bg-green-dark text-white-warm py-8">
  <div class="max-w-6xl mx-auto px-4 flex flex-col items-center gap-4">
    <div class="flex gap-6">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          class="hover:text-orange-light transition-colors"
        >
          <SocialIcon icon={link.icon} class="w-5 h-5" />
        </a>
      ))}
    </div>
    <p class="text-sm text-white-warm/60">
      &copy; {new Date().getFullYear()} Luciano Pulido &mdash; {t("footer.rights")}
    </p>
  </div>
</footer>
