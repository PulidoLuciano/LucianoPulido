---
import { useTranslations } from "../locales/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
---

<header class="sticky top-0 z-50 bg-green-dark text-white-warm">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={locale === "en" ? "/en/" : `/${locale}/`} class="text-xl font-bold tracking-tight">
      Luciano Pulido
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href={`/${locale}/blog`} class="hover:text-orange-light transition-colors">
        {t("nav.blog")}
      </a>
      <a href={`/${locale}/#projects`} class="hover:text-orange-light transition-colors">
        {t("nav.projects")}
      </a>
      <a href={`/${locale}/#experience`} class="hover:text-orange-light transition-colors">
        {t("nav.experience")}
      </a>
      <a href={`/${locale}/#about`} class="hover:text-orange-light transition-colors">
        {t("nav.about")}
      </a>
      <a href={`/${locale}/#contact`} class="hover:text-orange-light transition-colors">
        {t("nav.contact")}
      </a>
    </div>

    <div class="flex items-center gap-4">
      <LanguageSwitcher />
    </div>
  </nav>
</header>
