---
import { useTranslations } from "../../locales/utils";
import SectionWrapper from "../SectionWrapper.astro";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
---

<SectionWrapper class="min-h-screen flex items-center bg-green-dark text-white-warm">
  <div class="flex flex-col items-center text-center gap-6 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
      {t("hero.greeting")}
    </h1>
    <p class="text-xl md:text-2xl text-white-warm/80 max-w-2xl">
      {t("hero.subtitle")}
    </p>
    <a
      href={`/${locale}/#projects`}
      class="inline-block mt-4 px-8 py-3 bg-orange-light hover:bg-orange-dark text-green-dark font-semibold rounded-lg transition-colors"
    >
      {t("hero.cta")}
    </a>
  </div>
</SectionWrapper>
