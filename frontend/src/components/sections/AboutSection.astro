---
import { useTranslations } from "../../locales/utils";
import SectionWrapper from "../SectionWrapper.astro";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const skills = [
  "Python", "TypeScript", "SQL", "React", "Astro",
  "Docker", "AWS", "D3.js", "scikit-learn", "FastAPI",
];
---

<SectionWrapper id="about" class="bg-white-warm">
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{t("about.title")}</h2>

  <div class="grid md:grid-cols-2 gap-12 items-start max-w-5xl mx-auto">
    <div class="flex flex-col gap-4">
      <p class="text-lg leading-relaxed text-green-dark/80">{t("about.bio1")}</p>
      <p class="text-lg leading-relaxed text-green-dark/80">{t("about.bio2")}</p>
    </div>

    <div>
      <h3 class="text-xl font-semibold mb-4 text-green-dark">{t("about.skillsTitle")}</h3>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="px-3 py-1 bg-green-light/10 border border-green-light/30 rounded-full text-sm text-green-dark">
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</SectionWrapper>
