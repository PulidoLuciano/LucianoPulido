---
import type { Project } from "../../data/projects";

interface Props {
  project: Project;
  t: (key: string) => string;
}

const { project, t } = Astro.props;
---

<div class="bg-white-warm border border-green-light/20 rounded-xl overflow-hidden flex flex-col hover:border-green-light/50 transition-colors">
  <img
    src={project.image}
    alt={t(project.titleKey)}
    class="w-full h-48 object-cover"
    loading="lazy"
  />
  <div class="p-6 flex flex-col gap-4 flex-1">
  <h3 class="text-xl font-semibold">{t(project.titleKey)}</h3>
  <p class="text-green-dark/70 leading-relaxed flex-1">{t(project.descriptionKey)}</p>

  <div class="flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span class="px-2 py-0.5 bg-green-light/10 text-green-dark text-xs rounded-full font-medium">
        {tag}
      </span>
    ))}
  </div>

  <div class="flex gap-4 pt-2 border-t border-green-light/10">
    {project.liveUrl && (
      <a
        href={project.liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-orange-dark hover:text-orange-light transition-colors"
      >
        {t("projects.viewProject")} &rarr;
      </a>
    )}
    {project.sourceUrl && (
      <a
        href={project.sourceUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-green-light hover:text-green-dark transition-colors"
      >
        {t("projects.sourceCode")}
      </a>
    )}
  </div>
  </div>
</div>
