---
export const prerender = false;

import AdminLayout from "../../../../../layouts/AdminLayout.astro";
import PostForm from "../../../../../components/PostForm.astro";

const API_URL = process.env.API_URL || "http://localhost:8080";
const locale = Astro.currentLocale ?? "en";
const cookieHeader = Astro.request.headers.get("cookie") || "";
const adminHeaders: Record<string, string> = {
	"Content-Type": "application/json",
};
if (cookieHeader) {
	adminHeaders["Cookie"] = cookieHeader;
}

const id = parseInt(Astro.params.id || "");
if (isNaN(id)) {
	return Astro.redirect(`/${locale}/admin`);
}

interface RawCategory {
	id: number;
	slug: string;
	translations: Record<string, { name: string }>;
}

interface Category {
	id: number;
	slug: string;
	name: string;
}

interface PostData {
	slug: string;
	image_url: string | null;
	is_public: boolean;
	category_ids: number[];
	translations: Record<string, { title: string; content: string }>;
}

if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();

		const slug = formData.get("slug")?.toString() || "";
		const imageUrl = formData.get("image_url")?.toString() || null;
		const isPublic = formData.get("is_public") === "true";

		const catIdsRaw = formData.getAll("category_ids").map((v) => parseInt(v.toString()));
		const categoryIds = catIdsRaw.filter((n) => !isNaN(n));

		const enTitle = formData.get("en_title")?.toString() || "";
		const enContent = formData.get("en_content")?.toString() || "";
		const esTitle = formData.get("es_title")?.toString() || "";
		const esContent = formData.get("es_content")?.toString() || "";

		if (!slug || !enTitle || !esTitle) {
			console.error("Missing required fields");
		} else {
			const body = JSON.stringify({
				slug,
				image_url: imageUrl || null,
				is_public: isPublic,
				category_ids: categoryIds,
				translations: {
					en: { title: enTitle, content: enContent },
					es: { title: esTitle, content: esContent },
				},
			});

			const res = await fetch(`${API_URL}/api/admin/posts/${id}`, {
				method: "PUT",
				headers: adminHeaders,
				body,
			});

			if (res.status === 401) {
				return Astro.redirect(`/${locale}/admin/login`);
			}

			if (res.ok) {
				return Astro.redirect(`/${locale}/admin`);
			}
		}
	} catch (_) {}
}

let postData: PostData | null = null;
let categories: Category[] = [];
let fetchError = false;

try {
	const [postRes, catRes] = await Promise.all([
		fetch(`${API_URL}/api/admin/posts/${id}`, { headers: adminHeaders }),
		fetch(`${API_URL}/api/admin/categories?lang=en`, { headers: adminHeaders }),
	]);

	if (postRes.status === 401 || catRes.status === 401) {
		return Astro.redirect(`/${locale}/admin/login`);
	}

	if (postRes.ok) {
		postData = await postRes.json();
	} else {
		return Astro.redirect(`/${locale}/admin`);
	}

	if (catRes.ok) {
		const rawCategories: RawCategory[] = await catRes.json();
		categories = rawCategories.map((c) => ({
			id: c.id,
			slug: c.slug,
			name: c.translations?.en?.name || c.translations?.es?.name || c.slug,
		}));
	} else {
		fetchError = true;
	}
} catch (_) {
	fetchError = true;
}
---

<AdminLayout title={`Edit: ${postData?.slug ?? ""}`} locale={locale}>
	<h1 class="text-2xl font-bold mb-6">Edit Post</h1>

	{
		fetchError && (
			<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
				Failed to load data. Please try again.
			</div>
		)
	}

	{
		postData && (
			<PostForm mode="edit" locale={locale} categories={categories} postData={postData} />
		)
	}
</AdminLayout>
