---
export const prerender = false;

import { locales, useTranslations } from "../../locales/utils";
import { fetchPosts, fetchCategories } from "../../lib/api";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogSection from "../../components/sections/BlogSection.astro";

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1") || 1);
const perPage = Math.max(1, parseInt(Astro.url.searchParams.get("per_page") || "9") || 9);
const category = Astro.url.searchParams.get("category") || undefined;

const [data, categories] = await Promise.all([
	fetchPosts(locale, page, perPage, category),
	fetchCategories(locale),
]);
---

<BaseLayout>
	<BlogSection
		data={data}
		categories={categories ?? []}
		activeCategory={category}
		locale={locale}
		t={t}
	/>
</BaseLayout>
